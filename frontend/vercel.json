{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vitabalance.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api|assets|logo\\.png|favicon).*)",
      "destination": "/index.html"
    }
  ]
}
